DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_bastion
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-this-to-a-secure-random-string
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=http://localhost:5173
RUST_LOG=info,agent_bastion=debug

# Quickwit (audit log search engine)
QUICKWIT_URL=http://localhost:7280
QUICKWIT_INDEX=audit_logs

# Syslog (optional, UDP target for audit logs)
# SYSLOG_ADDR=127.0.0.1:514

# OIDC / SSO (Zitadel dev instance)
OIDC_ISSUER_URL=http://localhost:8080
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:3001/api/auth/sso/callback
